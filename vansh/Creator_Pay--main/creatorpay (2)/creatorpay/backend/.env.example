# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/creatorpay
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/creatorpay

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Web3 / Blockchain
# Infura or Alchemy endpoint for Ethereum
ETH_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id
ETH_RPC_URL_TESTNET=https://sepolia.infura.io/v3/your_infura_project_id

# Platform's hot wallet (receives crypto payments, then settles to creators)
PLATFORM_WALLET_PRIVATE_KEY=your_platform_wallet_private_key
PLATFORM_WALLET_ADDRESS=0xYourPlatformWalletAddress

# Bitcoin (using BlockCypher API for BTC monitoring)
BLOCKCYPHER_TOKEN=your_blockcypher_api_token
BTC_NETWORK=main   # or 'test3' for testnet

# Polygon
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/your_infura_project_id

# Platform fees (percentage, e.g. 2 = 2%)
PLATFORM_FEE_PERCENT=2

# Frontend URL (for CORS and redirect)
FRONTEND_URL=http://localhost:5173

# Admin email (seeded on first run)
ADMIN_EMAIL=admin@creatorpay.io
ADMIN_PASSWORD=ChangeMe123!
